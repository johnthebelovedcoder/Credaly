# ── Application ──────────────────────────────────────────────────────
APP_NAME=Credaly Scoring API
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/v1
CORS_ALLOWED_ORIGINS=https://admin.credaly.io

# ── Database ─────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./credaly.db

# Production (PostgreSQL) — uncomment and configure
# DATABASE_URL=postgresql+asyncpg://credaly:your_password@localhost:5432/credaly

POOL_SIZE=5
MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SCORE_CACHE_TTL_SECONDS=86400

# ── Security ─────────────────────────────────────────────────────────
# GENERATE YOUR OWN:
#   HMAC_SECRET_KEY: openssl rand -hex 64
#   CONSENT_SIGNING_SECRET: openssl rand -hex 64
#   BVN_ENCRYPTION_KEY: openssl rand -hex 32
HMAC_SECRET_KEY=dev-hmac-secret-key-change-in-production
CONSENT_SIGNING_SECRET=dev-consent-signing-secret-change-in-production
BVN_ENCRYPTION_KEY=dev-bvn-encryption-key-change-in-production

BCRYPT_ROUNDS=12

# ── Rate Limiting ────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT_PER_MINUTE=100

# ── ML Model ─────────────────────────────────────────────────────────
MODEL_REGISTRY_URI=./mlruns
MODEL_ARTIFACTS_PATH=./models
MIN_DATA_COVERAGE_PCT=30.0

# ── Scoring ──────────────────────────────────────────────────────────
SCORE_MIN=300
SCORE_MAX=850
CONFIDENCE_LEVEL=0.95

# ── Data Retention (months) ──────────────────────────────────────────
RAW_TRANSACTION_RETENTION_MONTHS=24
DERIVED_FEATURE_RETENTION_MONTHS=36
AUDIT_LOG_RETENTION_YEARS=7

# ── External APIs (Phase 0/1 — bureau only) ──────────────────────────
# Set these to your actual bureau API URLs and keys
CRC_API_URL=
CRC_API_KEY=
FIRSTCENTRAL_API_URL=
FIRSTCENTRAL_API_KEY=
CREDITREGISTRY_API_URL=
CREDITREGISTRY_API_KEY=

# Phase 2 — telco / mobile money
MTN_API_URL=
AIRTEL_API_URL=
OPAY_API_URL=
OPAY_API_KEY=
PALMPAY_API_URL=
PALMPAY_API_KEY=

# Open Banking partners
MONO_API_URL=
MONO_API_KEY=
OKRA_API_URL=
OKRA_API_KEY=
ONEPIPE_API_URL=
ONEPIPE_API_KEY=

# ── Webhook ──────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF_SECONDS=30

# ── Environment ──────────────────────────────────────────────────────
ENVIRONMENT=development
